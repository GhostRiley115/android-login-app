<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:background="@color/condo_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".WelcomeActivity">

        <ImageView
                android:id="@+id/imgBanner"
                android:layout_width="599dp"
                android:layout_height="650dp"
                android:translationY="160dp"
                android:alpha="0.20"
                android:scaleType="fitEnd"
                android:adjustViewBounds="true"
                android:src="@drawable/img_bg"
                android:contentDescription="Imagem de condominio"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="156dp"/>
        <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/logo_def"
                android:alpha="0.90"
                android:contentDescription="Logo do app"
                app:tint="@color/condo_title"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Bem-vindo ao seu condomínio"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/condo_title"
                android:textAlignment="center"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/imgLogo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Acesse boletos, faça reservas, cadastre visitantes e acompanhe tudo com praticidade em um só lugar."
                android:textSize="14sp"
                android:textColor="@color/condo_subtitle"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:paddingHorizontal="28dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.button.MaterialButton
                android:id="@+id/botaoIniciar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="85dp"
                android:text="Vamos começar"
                android:textColor="@color/condo_white"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:backgroundTint="#1F3A5F"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <View
                android:id="@+id/footerWelcomeGradient"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:background="@drawable/background_gradient"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>