<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/activityHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".HomeActivity" android:background="#FFFFFF" tools:layout_editor_absoluteY="491dp"
        tools:layout_editor_absoluteX="1dp">

    <TextView
            android:text="Olá, Fulano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/textViewHome"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" android:textSize="34sp" android:textColor="#C2185B"
            android:textColorHighlight="#FF0000" android:shadowColor="@color/black" android:shadowDx="3"
            android:shadowDy="3" android:shadowRadius="3"
            app:layout_constraintTop_toTopOf="parent" android:layout_marginBottom="38dp"
            app:layout_constraintBottom_toTopOf="@+id/button3" android:layout_marginTop="10dp"/>
    <Button
            android:text="Mural"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/button8"
            android:height="60dp"
            android:layout_marginEnd="15dp" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0" app:layout_constraintStart_toEndOf="@+id/button7"
            android:backgroundTint="#C2185B" android:layout_marginStart="10dp"
            app:layout_constraintBottom_toTopOf="@+id/button5" android:layout_marginBottom="88dp"
            android:shadowDx="0" android:shadowDy="10" android:shadowRadius="10" android:shadowColor="#070707"/>
    <Button
            android:text="Autorização"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/button7"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="15dp" android:height="60dp"
            app:layout_constraintEnd_toStartOf="@+id/button8"
            android:backgroundTint="#C2185B" android:layout_marginEnd="10dp"
            app:layout_constraintBottom_toTopOf="@+id/button4" android:layout_marginBottom="88dp"
            android:shadowDx="0" android:shadowDy="10" android:shadowRadius="10" android:shadowColor="#070707"/>
    <Button
            android:text="Boleto"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/btnBoleto"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="15dp" android:height="60dp"
            app:layout_constraintEnd_toStartOf="@+id/button3"
            android:backgroundTint="#C2185B" android:layout_marginEnd="10dp" android:layout_marginBottom="88dp"
            app:layout_constraintBottom_toTopOf="@+id/button7" android:shadowDx="0" android:shadowDy="10"
            android:shadowRadius="10" android:shadowColor="#070707"/>
    <Button
            android:text="Reserva"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/button3"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="15dp" android:height="60dp" app:layout_constraintStart_toEndOf="@+id/btnBoleto"
            android:backgroundTint="#C2185B" android:layout_marginStart="10dp" android:layout_marginBottom="88dp"
            app:layout_constraintBottom_toTopOf="@+id/button8" android:shadowDx="0" android:shadowDy="10"
            android:shadowRadius="10" android:shadowColor="#070707"/>
    <Button
            android:text="Prestação de Contas"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/button4"
            app:layout_constraintStart_toStartOf="parent"
            android:height="60dp" android:layout_marginStart="15dp"
            app:layout_constraintEnd_toStartOf="@+id/button5"
            android:layout_marginBottom="88dp"
            app:layout_constraintBottom_toTopOf="@+id/button" android:backgroundTint="#C2185B"
            android:layout_marginEnd="10dp" android:shadowDx="0" android:shadowDy="10" android:shadowRadius="10"
            android:shadowColor="#070707"/>
    <Button
            android:text="Contatos da Portaria"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/button"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            android:layout_marginEnd="15dp" android:layout_marginStart="15dp"
            app:layout_constraintHorizontal_bias="0.0" android:height="60dp" android:backgroundTint="#C2185B"
            app:layout_constraintBottom_toBottomOf="parent" android:layout_marginBottom="144dp"
            android:shadowDx="0" android:shadowDy="10" android:shadowRadius="10" android:shadowColor="#070707"/>
    <Button
            android:text="Mudança"
            android:layout_width="0dp"
            android:layout_height="wrap_content" android:id="@+id/button5"
            app:layout_constraintEnd_toEndOf="parent"
            android:height="60dp" android:layout_marginEnd="15dp"
            app:layout_constraintStart_toEndOf="@+id/button4" android:layout_marginBottom="88dp"
            app:layout_constraintBottom_toTopOf="@+id/button" android:backgroundTint="#C2185B"
            android:layout_marginStart="10dp" android:shadowDx="0" android:shadowDy="10" android:shadowRadius="10"
            android:shadowColor="#070707"
    />
</androidx.constraintlayout.widget.ConstraintLayout>