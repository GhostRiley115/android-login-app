<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:background="@drawable/background_gradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".WelcomeActivity">

        <ImageView
                android:id="@+id/imgBanner"
                android:layout_width="599dp"
                android:layout_height="650dp"
                android:translationY="160dp"
                android:alpha="0.20"
                android:scaleType="fitEnd"
                android:adjustViewBounds="true"
                android:src="@drawable/img_bg"
                android:contentDescription="Imagem de condominio"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
        />

        <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/logo_def"
                android:contentDescription="Logo do app"
                android:tint="#1E293B"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
        />

        <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Bem-vindo ao seu condomínio"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/imgLogo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Acesse boletos, faça reservas, cadastre visitantes e acompanhe tudo com praticidade em um só lugar."
                android:textSize="16sp"
                android:textColor="#64748B"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:paddingHorizontal="28dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
        />

        <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="76dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="15dp"

                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIniciar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Vamos começar"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowDx="0"
                        android:shadowDy="5"
                        android:shadowRadius="25"
                        android:background="@drawable/button_gradient"
                        app:backgroundTint="@null"/>

        </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>