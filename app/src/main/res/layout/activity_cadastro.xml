<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/activityCadastro"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/condo_background"
        tools:context=".CadastroActivity">

    <TextView
            android:id="@+id/tvCadastroTitulo"
            android:text="Cadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

    <TextView
            android:id="@+id/tvCadastroSubTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Crie sua conta para acessar boletos, reservas, seus visitantes e muito mais."
            android:textSize="14sp"
            android:textColor="#64748B"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@+id/tvCadastroTitulo"
            app:layout_constraintEnd_toEndOf="@+id/tilCadastroNome"
            app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCadastroNome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"

            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/condo_card"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="@color/textfield_stroke_color"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textfield_hint_color"

            app:layout_constraintTop_toBottomOf="@+id/tvCadastroSubTitulo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCadastroNome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Digite seu nome"
                android:inputType="text"
                android:textColor="@color/condo_text"
                android:textColorHint="@color/condo_text_disabled"
                android:textCursorDrawable="@drawable/cursor_azul"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCadastroEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"

            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/condo_card"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="@color/textfield_stroke_color"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textfield_hint_color"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilCadastroNome">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCadastroEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Digite seu e-mail"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/condo_text"
                    android:textColorHint="@color/condo_text_disabled"
                    android:textCursorDrawable="@drawable/cursor_azul"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCadastroContato"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"

            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/condo_card"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="@color/textfield_stroke_color"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textfield_hint_color"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilCadastroEmail">

        <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCadastroContato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Numero para contato"
                android:inputType="phone"
                android:textColor="@color/condo_text"
                android:textColorHint="@color/condo_text_disabled"
                android:textCursorDrawable="@drawable/cursor_azul"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCadastroVinculo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/condo_card"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:endIconMode="dropdown_menu"
            app:hintTextColor="@color/textfield_hint_color"
            app:layout_constraintTop_toBottomOf="@id/tilCadastroContato"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etCadastroVinculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tipo de vínculo"
                android:inputType="none"
                android:textColor="@color/condo_text"
                android:textColorHint="@color/condo_text_disabled"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCadastroSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"

            app:endIconMode="password_toggle"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/condo_card"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="@color/textfield_stroke_color"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textfield_hint_color"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilCadastroVinculo">

        <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCadastroSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Crie sua senha"
                android:inputType="textPassword"
                android:textColor="@color/condo_text"
                android:textColorHint="@color/condo_text_disabled"
                android:textCursorDrawable="@drawable/cursor_azul"/>
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCadastroConfirmarSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"

            app:endIconMode="password_toggle"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="@color/condo_card"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeColor="@color/textfield_stroke_color"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textfield_hint_color"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tilCadastroSenha">

        <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCadastroConfirmarSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirme sua senha"
                android:inputType="textPassword"
                android:textColor="@color/condo_text"
                android:textColorHint="@color/condo_text_disabled"
                android:textCursorDrawable="@drawable/cursor_azul"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
            android:id="@+id/botaoCadastrar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="Finalizar cadastro"
            android:textColor="@color/condo_white"
            android:textStyle="bold"
            app:cornerRadius="20dp"
            app:backgroundTint="#1F3A5F"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilCadastroConfirmarSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>